<UserControl
	x:Class="TombEditor.Views.ObjectBrushToolboxView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:DarkUI.WPF.CustomControls;assembly=DarkUI.WPF"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:darkUI="clr-namespace:DarkUI.WPF;assembly=DarkUI.WPF"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	d:DesignHeight="84"
	d:DesignWidth="430"
	Background="{DynamicResource Brush_Background}"
	Foreground="{DynamicResource Brush_Text}"
	SnapsToDevicePixels="{x:Static darkUI:Defaults.SnapsToDevicePixels}"
	UseLayoutRounding="{x:Static darkUI:Defaults.UseLayoutRounding}"
	mc:Ignorable="d">

	<Grid Margin="2" Grid.IsSharedSizeScope="True">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!--  Row 0: Radius, Density, Rotation, Flip  -->
		<StackPanel
			Grid.Row="0"
			Margin="0,0,0,3"
			Orientation="Horizontal">
			<Label
				MinWidth="54"
				Margin="0,0,4,0"
				Padding="0"
				VerticalAlignment="Center"
				Content="Radius:" />
			<controls:NumericUpDown
				x:Name="nudRadius"
				Width="56"
				FormatString="F1"
				Increment="0.1"
				Maximum="25"
				Minimum="0.1"
				TextAlignment="Left"
				Value="0.5" />
			<Label
				MinWidth="54"
				Margin="12,0,4,0"
				Padding="0"
				VerticalAlignment="Center"
				Content="Density:" />
			<controls:NumericUpDown
				x:Name="nudDensity"
				Width="56"
				FormatString="F2"
				Increment="0.05"
				Maximum="5"
				Minimum="0.01"
				TextAlignment="Left"
				Value="1.0" />
			<Label
				MinWidth="54"
				Margin="12,0,4,0"
				Padding="0"
				VerticalAlignment="Center"
				Content="Rotation:" />
			<controls:NumericUpDown
				x:Name="nudRotation"
				Width="56"
				FormatString="F1"
				Increment="5"
				Maximum="360"
				Minimum="0"
				TextAlignment="Left"
				Value="0" />
			<CheckBox
				x:Name="chkPerpendicular"
				Margin="8,0,0,0"
				VerticalAlignment="Center"
				Content="Flip" />
		</StackPanel>

		<!--  Row 1: Random rotation | Follow mouse direction | Random scale + NUDs  -->
		<Grid Grid.Row="1" Margin="0,0,0,3">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" SharedSizeGroup="LeftCol" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<StackPanel Grid.Column="0" Orientation="Horizontal">
				<CheckBox
					x:Name="chkRandomRotation"
					VerticalAlignment="Center"
					Content="Random rotation" />
				<CheckBox
					x:Name="chkFollowMouseDirection"
					Margin="8,0,0,0"
					VerticalAlignment="Center"
					Content="Follow mouse direction" />
			</StackPanel>

			<StackPanel Grid.Column="1" Orientation="Horizontal">
				<CheckBox
					x:Name="chkRandomScale"
					Margin="8,0,0,0"
					VerticalAlignment="Center"
					Content="Random scale:" />
				<controls:NumericUpDown
					x:Name="nudScaleMin"
					Width="56"
					Margin="4,0,0,0"
					FormatString="F2"
					Increment="0.05"
					Maximum="10"
					Minimum="0.1"
					TextAlignment="Left"
					Value="0.8" />
				<Label
					Padding="2,0"
					VerticalAlignment="Center"
					Content="-" />
				<controls:NumericUpDown
					x:Name="nudScaleMax"
					Width="56"
					FormatString="F2"
					Increment="0.05"
					Maximum="10"
					Minimum="0.1"
					TextAlignment="Left"
					Value="1.2" />
			</StackPanel>
		</Grid>

		<!--  Row 2: Fit to floor | Place in adjacent rooms  -->
		<Grid Grid.Row="2">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" SharedSizeGroup="LeftCol" />
				<ColumnDefinition Width="*" />
			</Grid.ColumnDefinitions>

			<CheckBox
				x:Name="chkFitToGround"
				Grid.Column="0"
				VerticalAlignment="Center"
				Content="Fit to floor" />
			<CheckBox
				x:Name="chkAdjacentRooms"
				Grid.Column="1"
				Margin="8,0,0,0"
				VerticalAlignment="Center"
				Content="Place in adjacent rooms" />
		</Grid>
	</Grid>
</UserControl>
