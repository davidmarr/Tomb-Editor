<UserControl
	x:Class="TombEditor.Views.ContentBrowserView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:DarkUI.WPF.CustomControls;assembly=DarkUI.WPF"
	xmlns:converters="clr-namespace:DarkUI.WPF.Converters;assembly=DarkUI.WPF"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:darkUI="clr-namespace:DarkUI.WPF;assembly=DarkUI.WPF"
	xmlns:local="clr-namespace:TombEditor.Views"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:tombLib="clr-namespace:TombLib.WPF;assembly=TombLib.WPF"
	xmlns:viewModels="clr-namespace:TombEditor.ViewModels"
	d:DataContext="{d:DesignInstance Type=viewModels:ContentBrowserViewModel}"
	d:DesignHeight="400"
	d:DesignWidth="350"
	Background="{DynamicResource Brush_Background}"
	SnapsToDevicePixels="{x:Static darkUI:Defaults.SnapsToDevicePixels}"
	UseLayoutRounding="{x:Static darkUI:Defaults.UseLayoutRounding}"
	mc:Ignorable="d">

	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
		<converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter" />

		<!--  Asset tile item template  -->
		<DataTemplate x:Key="AssetTileTemplate" DataType="{x:Type viewModels:AssetItemViewModel}">
			<Border
				x:Name="TileBorder"
				Width="{Binding DataContext.TileWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
				Height="{Binding DataContext.TileHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
				Margin="2"
				Background="Transparent"
				BorderBrush="Transparent"
				BorderThickness="1"
				CornerRadius="2"
				Cursor="Hand"
				ToolTipService.InitialShowDelay="400">
				<Border.ToolTip>
					<StackPanel MaxWidth="280">
						<TextBlock
							FontWeight="SemiBold"
							Foreground="{DynamicResource Brush_Text}"
							Text="{Binding Name}" />
						<TextBlock
							Foreground="{DynamicResource Brush_Text}"
							Opacity="0.7"
							Text="{Binding CategoryDisplayText}" />
						<TextBlock
							Foreground="{DynamicResource Brush_Text}"
							Opacity="0.6"
							Text="{Binding WadSource, StringFormat='Source: {0}'}" />
					</StackPanel>
				</Border.ToolTip>

				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<!--  Thumbnail area  -->
					<Grid
						Grid.Row="0"
						Width="{Binding DataContext.ThumbSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
						Height="{Binding DataContext.ThumbSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
						Margin="0,4,0,0"
						HorizontalAlignment="Center">

						<!--  Rendered 3D thumbnail (shown when available)  -->
						<Border CornerRadius="3" Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVisConverter}}">
							<Border.Effect>
								<DropShadowEffect
									BlurRadius="4"
									Direction="270"
									Opacity="0.3"
									ShadowDepth="1"
									Color="Black" />
							</Border.Effect>

							<Border ClipToBounds="True" CornerRadius="3">
								<Image
									RenderOptions.BitmapScalingMode="HighQuality"
									Source="{Binding Thumbnail}"
									Stretch="Uniform" />
							</Border>
						</Border>

						<!--  Placeholder (shown when no thumbnail)  -->
						<Border
							Background="{Binding ThumbnailBrush}"
							CornerRadius="3"
							Visibility="{Binding HasThumbnail, Converter={StaticResource InverseBoolToVisConverter}}">
							<Border.Effect>
								<DropShadowEffect
									BlurRadius="4"
									Direction="270"
									Opacity="0.3"
									ShadowDepth="1"
									Color="Black" />
							</Border.Effect>

							<TextBlock
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								FontSize="18"
								FontWeight="Bold"
								Foreground="White"
								Opacity="0.9"
								Text="{Binding Initials}" />
						</Border>

						<!--  Favorite star toggle (top-right corner of thumbnail)  -->
						<Border
							x:Name="FavoriteStar"
							Width="16"
							Height="16"
							Margin="0,3,3,0"
							HorizontalAlignment="Right"
							VerticalAlignment="Top"
							Background="Transparent"
							Cursor="Hand"
							MouseLeftButtonDown="FavoriteStar_MouseLeftButtonDown"
							Opacity="0">
							<Image
								x:Name="FavoriteStarImage"
								RenderOptions.BitmapScalingMode="HighQuality"
								Source="/Resources/icons_actions/actions_StarOutlined-16.png"
								Stretch="Uniform" />
						</Border>
					</Grid>

					<!--  Asset name  -->
					<TextBlock
						Grid.Row="1"
						Margin="2,2,2,0"
						HorizontalAlignment="Center"
						VerticalAlignment="Top"
						FontSize="10"
						Foreground="{DynamicResource Brush_Text}"
						Text="{Binding Name}"
						TextAlignment="Center"
						TextTrimming="CharacterEllipsis"
						TextWrapping="NoWrap" />
				</Grid>
			</Border>

			<DataTemplate.Triggers>
				<!--  Hover effect (non-selected items only, because selection trigger below takes priority)  -->
				<Trigger SourceName="TileBorder" Property="IsMouseOver" Value="True">
					<Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource Brush_Background_Alternative}" />
					<Setter TargetName="FavoriteStar" Property="Opacity" Value="0.6" />
				</Trigger>

				<!--  Show filled star when item is a favorite.  -->
				<DataTrigger Binding="{Binding IsFavorite}" Value="True">
					<Setter TargetName="FavoriteStarImage" Property="Source" Value="/Resources/icons_actions/actions_StarFilled-16.png" />
					<Setter TargetName="FavoriteStar" Property="Opacity" Value="1" />
				</DataTrigger>

				<!--  Selection always wins (declared last = highest priority)  -->
				<DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
					<Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource Brush_Selection}" />
					<Setter TargetName="TileBorder" Property="BorderBrush" Value="{DynamicResource Brush_Highlight}" />
				</DataTrigger>
				<DataTrigger Binding="{Binding IsRubberBandSelected}" Value="True">
					<Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource Brush_Selection}" />
					<Setter TargetName="TileBorder" Property="BorderBrush" Value="{DynamicResource Brush_Highlight}" />
				</DataTrigger>
			</DataTemplate.Triggers>
		</DataTemplate>

		<!--  ListBoxItem container style for selection + keyboard focus  -->
		<Style x:Key="AssetListBoxItemStyle" TargetType="ListBoxItem">
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ListBoxItem">
						<ContentPresenter />
					</ControlTemplate>
				</Setter.Value>
			</Setter>

			<Setter Property="Padding" Value="0" />
			<Setter Property="Margin" Value="0" />
			<Setter Property="Focusable" Value="True" />
		</Style>
	</UserControl.Resources>

	<Grid
		AllowDrop="True"
		DragEnter="ContentBrowser_DragEnter"
		DragOver="ContentBrowser_DragEnter"
		Drop="ContentBrowser_Drop">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!--  Header bar: Search + Category filter  -->
		<Border
			Grid.Row="0"
			Padding="4"
			BorderBrush="{DynamicResource Brush_Border_Low}"
			BorderThickness="0,0,0,1">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

				<!--  Search box  -->
				<Grid Grid.Column="0" Margin="0,0,4,0">
					<TextBox
						Padding="2,1,18,1"
						VerticalContentAlignment="Center"
						FontSize="11"
						Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}">
						<darkUI:WatermarkService.Watermark>
							<TextBlock
								FontSize="11"
								Foreground="{DynamicResource Brush_Text}"
								Opacity="0.4"
								Text="{tombLib:Localize SearchPlaceholder}" />
						</darkUI:WatermarkService.Watermark>
					</TextBox>

					<Border
						Width="14"
						Height="14"
						Margin="0,0,4,0"
						HorizontalAlignment="Right"
						VerticalAlignment="Center"
						Background="Transparent"
						Cursor="Hand">
						<Border.InputBindings>
							<MouseBinding Command="{Binding ClearSearchCommand}" MouseAction="LeftClick" />
						</Border.InputBindings>
						<Border.Style>
							<Style TargetType="Border">
								<Setter Property="Visibility" Value="Visible" />
								<Style.Triggers>
									<DataTrigger Binding="{Binding SearchText}" Value="">
										<Setter Property="Visibility" Value="Collapsed" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</Border.Style>

						<TextBlock
							VerticalAlignment="Center"
							FontSize="7"
							Foreground="{DynamicResource Brush_Text}"
							Opacity="0.6"
							Text="&#x2715;"
							TextAlignment="Center" />
					</Border>
				</Grid>

				<!--  Type filter  -->
				<ComboBox
					Grid.Column="1"
					Width="140"
					VerticalAlignment="Center"
					FontSize="11"
					ItemsSource="{Binding FilterOptions}"
					SelectedItem="{Binding SelectedFilter}">
					<ComboBox.ItemTemplate>
						<DataTemplate>
							<Grid HorizontalAlignment="Stretch">
								<!--  Splitter: horizontal line for non-selectable separator  -->
								<Separator
									Margin="0"
									Background="{DynamicResource Brush_Border_Low}"
									Visibility="{Binding IsSplitter, Converter={StaticResource BoolToVisConverter}}" />

								<!--  Normal filter label  -->
								<TextBlock Text="{Binding DisplayName}">
									<TextBlock.Style>
										<Style TargetType="TextBlock">
											<Setter Property="Visibility" Value="Visible" />

											<Style.Triggers>
												<DataTrigger Binding="{Binding IsSplitter}" Value="True">
													<Setter Property="Visibility" Value="Collapsed" />
												</DataTrigger>
											</Style.Triggers>
										</Style>
									</TextBlock.Style>
								</TextBlock>
							</Grid>
						</DataTemplate>
					</ComboBox.ItemTemplate>

					<ComboBox.ItemContainerStyle>
						<Style BasedOn="{StaticResource {x:Type ComboBoxItem}}" TargetType="ComboBoxItem">
							<Style.Triggers>
								<DataTrigger Binding="{Binding IsSplitter}" Value="True">
									<Setter Property="IsEnabled" Value="False" />
									<Setter Property="IsHitTestVisible" Value="False" />
									<Setter Property="Focusable" Value="False" />
									<Setter Property="Height" Value="5" />
									<Setter Property="Padding" Value="0" />
									<Setter Property="Margin" Value="0" />
									<Setter Property="HorizontalContentAlignment" Value="Stretch" />
								</DataTrigger>
							</Style.Triggers>
						</Style>
					</ComboBox.ItemContainerStyle>
				</ComboBox>
			</Grid>
		</Border>

		<!--  Main content: Scrollable tile grid  -->
		<ListBox
			x:Name="AssetListBox"
			Grid.Row="1"
			Background="Transparent"
			BorderThickness="0"
			ItemContainerStyle="{StaticResource AssetListBoxItemStyle}"
			ItemTemplate="{StaticResource AssetTileTemplate}"
			ItemsSource="{Binding FilteredItems}"
			KeyDown="AssetListBox_KeyDown"
			MouseLeave="AssetListBox_MouseLeave"
			PreviewMouseDoubleClick="AssetListBox_PreviewMouseDoubleClick"
			PreviewMouseLeftButtonDown="AssetListBox_PreviewMouseLeftButtonDown"
			PreviewMouseLeftButtonUp="AssetListBox_PreviewMouseLeftButtonUp"
			PreviewMouseMove="AssetListBox_PreviewMouseMove"
			PreviewMouseWheel="AssetListBox_PreviewMouseWheel"
			ScrollViewer.HorizontalScrollBarVisibility="Disabled"
			ScrollViewer.ScrollChanged="AssetListBox_ScrollChanged"
			SelectedItem="{Binding SelectedItem, Mode=OneWay}"
			SelectionChanged="AssetListBox_SelectionChanged"
			SelectionMode="Extended"
			VirtualizingPanel.IsVirtualizing="False">

			<ListBox.ItemsPanel>
				<ItemsPanelTemplate>
					<WrapPanel Orientation="Horizontal" />
				</ItemsPanelTemplate>
			</ListBox.ItemsPanel>
		</ListBox>

		<!--  Rubber-band selection rectangle overlay (drawn on top, non-interactive)  -->
		<Canvas
			x:Name="RubberBandCanvas"
			Grid.Row="1"
			IsHitTestVisible="False">
			<Border
				x:Name="SelectionRect"
				Background="#20007ACC"
				BorderBrush="#FF007ACC"
				BorderThickness="1"
				Visibility="Collapsed" />
		</Canvas>

		<!--  Empty state message (shown when no WADs are loaded)  -->
		<Border
			Grid.Row="1"
			Background="Transparent"
			IsHitTestVisible="True"
			Visibility="{Binding HasLoadedWads, Converter={StaticResource InverseBoolToVisConverter}}">
			<Border.InputBindings>
				<MouseBinding Command="{Binding AddWadCommand}" MouseAction="LeftClick" />
			</Border.InputBindings>

			<TextBlock
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				Cursor="Hand"
				FontSize="11"
				Foreground="{DynamicResource Brush_Text}"
				Opacity="0.5"
				Text="{tombLib:Localize EmptyStateMessage}"
				TextAlignment="Center" />
		</Border>

		<!--  Status bar: Tile slider + Wad source + Item count  -->
		<Border
			Grid.Row="2"
			Padding="4,3"
			BorderBrush="{DynamicResource Brush_Border_Low}"
			BorderThickness="0,1,0,0">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

				<!--  Tile size slider  -->
				<StackPanel
					Grid.Column="0"
					Margin="0,0,6,0"
					VerticalAlignment="Center"
					Orientation="Horizontal">
					<TextBlock
						VerticalAlignment="Center"
						FontSize="9"
						Foreground="{DynamicResource Brush_Text}"
						Opacity="0.5"
						Text="{tombLib:Localize Size}" />
					<Slider
						Width="60"
						Margin="4,0,0,0"
						VerticalAlignment="Center"
						IsSnapToTickEnabled="True"
						Maximum="{Binding MaxTileWidth}"
						Minimum="{Binding MinTileWidth}"
						TickFrequency="4"
						Value="{Binding TileWidth}" />
				</StackPanel>

				<TextBlock
					Grid.Column="1"
					VerticalAlignment="Center"
					FontSize="10"
					Foreground="{DynamicResource Brush_Text}"
					Opacity="0.7"
					Text="{Binding SelectedItemWadInfo}"
					TextTrimming="CharacterEllipsis" />

				<TextBlock
					Grid.Column="2"
					VerticalAlignment="Center"
					FontSize="10"
					Foreground="{DynamicResource Brush_Text}"
					Opacity="0.5"
					Text="{Binding FormattedItemCount}" />
			</Grid>
		</Border>
	</Grid>
</UserControl>
