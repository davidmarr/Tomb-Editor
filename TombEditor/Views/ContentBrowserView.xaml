<UserControl
	x:Class="TombEditor.Views.ContentBrowserView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:DarkUI.WPF.CustomControls;assembly=DarkUI.WPF"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:darkUI="clr-namespace:DarkUI.WPF;assembly=DarkUI.WPF"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:viewModels="clr-namespace:TombEditor.ViewModels"
	d:DataContext="{d:DesignInstance Type=viewModels:ContentBrowserViewModel}"
	d:DesignHeight="400"
	d:DesignWidth="350"
	Background="{DynamicResource Brush_Background}"
	SnapsToDevicePixels="{x:Static darkUI:Defaults.SnapsToDevicePixels}"
	UseLayoutRounding="{x:Static darkUI:Defaults.UseLayoutRounding}"
	mc:Ignorable="d">

	<UserControl.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

		<!--  Inverted boolean to visibility (visible when false)  -->
		<Style x:Key="HideWhenTrueStyle" TargetType="FrameworkElement">
			<Setter Property="Visibility" Value="Visible" />
			<Style.Triggers>
				<DataTrigger Binding="{Binding HasThumbnail}" Value="True">
					<Setter Property="Visibility" Value="Collapsed" />
				</DataTrigger>
			</Style.Triggers>
		</Style>

		<!--  Slider styles matching DarkUI.WPF  -->
		<Style x:Key="SliderRepeatButtonStyle" TargetType="RepeatButton">
			<Setter Property="OverridesDefaultStyle" Value="True" />
			<Setter Property="IsTabStop" Value="False" />
			<Setter Property="Focusable" Value="False" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="RepeatButton">
						<Border Background="Transparent" />
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="SliderThumbStyle" TargetType="Thumb">
			<Setter Property="OverridesDefaultStyle" Value="True" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Thumb">
						<Border
							Width="10"
							Height="16"
							Background="{DynamicResource Brush_Background_High}"
							BorderBrush="{DynamicResource Brush_Border}"
							BorderThickness="1"
							CornerRadius="2" />
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="DarkSliderStyle" TargetType="Slider">
			<Setter Property="OverridesDefaultStyle" Value="True" />
			<Setter Property="SnapsToDevicePixels" Value="True" />
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Slider">
						<Grid VerticalAlignment="Center">
							<Border
								Height="4"
								Margin="5,0"
								Background="{DynamicResource Brush_Background_Low}"
								BorderBrush="{DynamicResource Brush_Border}"
								BorderThickness="1"
								CornerRadius="2" />
							<Track x:Name="PART_Track">
								<Track.DecreaseRepeatButton>
									<RepeatButton Command="Slider.DecreaseLarge" Style="{StaticResource SliderRepeatButtonStyle}" />
								</Track.DecreaseRepeatButton>
								<Track.Thumb>
									<Thumb Style="{StaticResource SliderThumbStyle}" />
								</Track.Thumb>
								<Track.IncreaseRepeatButton>
									<RepeatButton Command="Slider.IncreaseLarge" Style="{StaticResource SliderRepeatButtonStyle}" />
								</Track.IncreaseRepeatButton>
							</Track>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!--  Asset tile item template  -->
		<DataTemplate x:Key="AssetTileTemplate" DataType="{x:Type viewModels:AssetItemViewModel}">
			<Border
				x:Name="TileBorder"
				Width="{Binding DataContext.TileWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
				Height="{Binding DataContext.TileHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
				Margin="2"
				Background="Transparent"
				BorderBrush="Transparent"
				BorderThickness="1"
				CornerRadius="2"
				Cursor="Hand"
				ToolTipService.InitialShowDelay="400">
				<Border.ToolTip>
					<StackPanel MaxWidth="280">
						<TextBlock
							FontWeight="SemiBold"
							Foreground="{DynamicResource Brush_Text}"
							Text="{Binding Name}" />
						<TextBlock
							Foreground="{DynamicResource Brush_Text}"
							Opacity="0.7"
							Text="{Binding CategoryName}" />
						<TextBlock
							Foreground="{DynamicResource Brush_Text}"
							Opacity="0.6"
							Text="{Binding WadSource, StringFormat='Source: {0}'}" />
					</StackPanel>
				</Border.ToolTip>

				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
					</Grid.RowDefinitions>

					<!--  Thumbnail area  -->
					<Grid
						Grid.Row="0"
						Width="{Binding DataContext.ThumbSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
						Height="{Binding DataContext.ThumbSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
						Margin="0,4,0,0"
						HorizontalAlignment="Center">

						<!--  Rendered 3D thumbnail (shown when available)  -->
						<Border
							CornerRadius="3"
							Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVisConverter}}">
							<Border.Effect>
								<DropShadowEffect
									BlurRadius="4"
									Direction="270"
									Opacity="0.3"
									ShadowDepth="1"
									Color="Black" />
							</Border.Effect>
							<Border CornerRadius="3" ClipToBounds="True">
								<Image
									Source="{Binding Thumbnail}"
									Stretch="Uniform"
									RenderOptions.BitmapScalingMode="HighQuality" />
							</Border>
						</Border>

						<!--  Placeholder (shown when no thumbnail)  -->
						<Border
							Background="{Binding ThumbnailBrush}"
							CornerRadius="3"
							Style="{StaticResource HideWhenTrueStyle}">
							<Border.Effect>
								<DropShadowEffect
									BlurRadius="4"
									Direction="270"
									Opacity="0.3"
									ShadowDepth="1"
									Color="Black" />
							</Border.Effect>

							<TextBlock
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								FontSize="18"
								FontWeight="Bold"
								Foreground="White"
								Opacity="0.9"
								Text="{Binding Initials}" />
						</Border>
					</Grid>

					<!--  Asset name  -->
					<TextBlock
						Grid.Row="1"
						Margin="2,2,2,0"
						HorizontalAlignment="Center"
						VerticalAlignment="Top"
						FontSize="10"
						Foreground="{DynamicResource Brush_Text}"
						Text="{Binding Name}"
						TextAlignment="Center"
						TextTrimming="CharacterEllipsis"
						TextWrapping="NoWrap" />
				</Grid>
			</Border>

			<DataTemplate.Triggers>
				<!--  Hover effect (non-selected items only, because selection trigger below takes priority)  -->
				<Trigger SourceName="TileBorder" Property="IsMouseOver" Value="True">
					<Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource Brush_Background_Alternative}" />
				</Trigger>
				<!--  Selection always wins (declared last = highest priority)  -->
				<DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
					<Setter TargetName="TileBorder" Property="Background" Value="{DynamicResource Brush_Selection}" />
					<Setter TargetName="TileBorder" Property="BorderBrush" Value="{DynamicResource Brush_Highlight}" />
				</DataTrigger>
			</DataTemplate.Triggers>
		</DataTemplate>

		<!--  ListBoxItem container style for selection + keyboard focus  -->
		<Style x:Key="AssetListBoxItemStyle" TargetType="ListBoxItem">
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="ListBoxItem">
						<ContentPresenter />
					</ControlTemplate>
				</Setter.Value>
			</Setter>
			<Setter Property="Padding" Value="0" />
			<Setter Property="Margin" Value="0" />
			<Setter Property="Focusable" Value="True" />
		</Style>
	</UserControl.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
			<RowDefinition Height="Auto" />
		</Grid.RowDefinitions>

		<!--  Header bar: Search + Category filter  -->
		<Border
			Grid.Row="0"
			Padding="4"
			BorderBrush="{DynamicResource Brush_Border_Low}"
			BorderThickness="0,0,0,1">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

				<!--  Search box  -->
				<Grid Grid.Column="0">
					<TextBox
						x:Name="SearchBox"
						Padding="2,1,18,1"
						VerticalContentAlignment="Center"
						FontSize="11"
						Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged, Delay=150}" />
					<TextBlock
						Margin="6,0,0,0"
						VerticalAlignment="Center"
						FontSize="11"
						Foreground="{DynamicResource Brush_Text}"
						IsHitTestVisible="False"
						Opacity="0.4"
						Text="Search assets...">
						<TextBlock.Style>
							<Style TargetType="TextBlock">
								<Setter Property="Visibility" Value="Collapsed" />
								<Style.Triggers>
									<DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
										<Setter Property="Visibility" Value="Visible" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</TextBlock.Style>
					</TextBlock>
					<Button
						Width="14"
						Height="14"
						Margin="0,0,4,0"
						HorizontalAlignment="Right"
						VerticalAlignment="Center"
						Command="{Binding ClearSearchCommand}"
						Content="✕"
						FontSize="7"
						Padding="0"
						BorderThickness="0"
						Background="Transparent"
						Foreground="{DynamicResource Brush_Text}"
						Opacity="0.6"
						Cursor="Hand">
						<Button.Style>
							<Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
								<Setter Property="Visibility" Value="Visible" />
								<Style.Triggers>
									<DataTrigger Binding="{Binding SearchText}" Value="">
										<Setter Property="Visibility" Value="Collapsed" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</Button.Style>
					</Button>
				</Grid>

				<!--  Separator  -->
				<Rectangle
					Grid.Column="1"
					Width="1"
					Margin="4,2"
					Fill="{DynamicResource Brush_Border_Low}" />

				<!--  Type filter  -->
				<ComboBox
					Grid.Column="2"
					Width="120"
					VerticalAlignment="Center"
					FontSize="11"
					ItemsSource="{Binding Categories}"
					SelectedItem="{Binding SelectedCategory}">
					<ComboBox.ItemTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding}" />
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>
			</Grid>
		</Border>

		<!--  Main content: Scrollable tile grid  -->
		<ListBox
			x:Name="AssetListBox"
			Grid.Row="1"
			Background="Transparent"
			BorderThickness="0"
			ItemContainerStyle="{StaticResource AssetListBoxItemStyle}"
			ItemTemplate="{StaticResource AssetTileTemplate}"
			ItemsSource="{Binding FilteredItems}"
			KeyDown="AssetListBox_KeyDown"
			MouseDoubleClick="AssetListBox_MouseDoubleClick"
			PreviewMouseLeftButtonDown="AssetListBox_PreviewMouseLeftButtonDown"
			PreviewMouseMove="AssetListBox_PreviewMouseMove"
			ScrollViewer.HorizontalScrollBarVisibility="Disabled"
			SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
			SelectionMode="Single"
			VirtualizingPanel.IsVirtualizing="False">

			<ListBox.ContextMenu>
				<ContextMenu>
					<MenuItem Header="Locate Item" Command="{Binding LocateItemCommand}" />
					<MenuItem Header="Add Item" Command="{Binding AddItemCommand}" />
				</ContextMenu>
			</ListBox.ContextMenu>

			<ListBox.ItemsPanel>
				<ItemsPanelTemplate>
					<WrapPanel Orientation="Horizontal" />
				</ItemsPanelTemplate>
			</ListBox.ItemsPanel>
		</ListBox>

		<!--  Status bar: Tile slider + Wad source + Item count  -->
		<Border
			Grid.Row="2"
			Padding="4,3"
			BorderBrush="{DynamicResource Brush_Border_Low}"
			BorderThickness="0,1,0,0">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto" />
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>

				<!--  Tile size slider  -->
				<StackPanel
					Grid.Column="0"
					Margin="0,0,6,0"
					Orientation="Horizontal"
					VerticalAlignment="Center">
					<TextBlock
						VerticalAlignment="Center"
						FontSize="9"
						Foreground="{DynamicResource Brush_Text}"
						Opacity="0.5"
						Text="Size" />
					<Slider
						Width="60"
						Margin="4,0,0,0"
						VerticalAlignment="Center"
						IsSnapToTickEnabled="True"
						Maximum="{Binding MaxTileWidth}"
						Minimum="{Binding MinTileWidth}"
						TickFrequency="4"
						Style="{StaticResource DarkSliderStyle}"
						Value="{Binding TileWidth}" />
				</StackPanel>

				<TextBlock
					Grid.Column="1"
					VerticalAlignment="Center"
					FontSize="10"
					Foreground="{DynamicResource Brush_Text}"
					Opacity="0.7"
					Text="{Binding SelectedItemWadInfo}"
					TextTrimming="CharacterEllipsis" />

				<TextBlock
					Grid.Column="2"
					VerticalAlignment="Center"
					FontSize="10"
					Foreground="{DynamicResource Brush_Text}"
					Opacity="0.5"
					Text="{Binding ItemCount, StringFormat='{}{0} items'}" />
			</Grid>
		</Border>
	</Grid>
</UserControl>
