<Window
    x:Class="TombEditor.FlybyManager.FlybyManagerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:DarkUI.WPF.CustomControls;assembly=DarkUI.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:darkUI="clr-namespace:DarkUI.WPF;assembly=DarkUI.WPF"
    xmlns:local="clr-namespace:TombEditor.FlybyManager"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sg="clr-namespace:SpacedGridControl;assembly=SpacedGridControl"
    Title="Flyby Sequence Manager"
    Width="960"
    Height="620"
    MinWidth="760"
    MinHeight="500"
    Background="{DynamicResource Brush_Background}"
    ResizeMode="CanResize"
    Style="{DynamicResource CustomWindowStyle}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">

    <sg:SpacedGrid Margin="{x:Static darkUI:Defaults.MediumThickness}" RowSpacing="{x:Static darkUI:Defaults.MediumThicknessWidth}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" MinWidth="150" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Row 0: Sequence selector spanning all columns -->
        <sg:SpacedGrid Grid.Row="0" Grid.ColumnSpan="3" ColumnSpacing="{x:Static darkUI:Defaults.MediumThicknessWidth}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" VerticalAlignment="Center" Content="Sequence:" />

            <ComboBox
                Grid.Column="1"
                Width="70"
                ItemsSource="{Binding AvailableSequences}"
                SelectedItem="{Binding SelectedSequence}" />

            <Button
                Grid.Column="2"
                Width="24"
                Height="24"
                Command="{Binding AddSequenceCommand}"
                ToolTip="Add new sequence">
                <Image Source="/TombEditor;component/Resources/icons_general/general_plus_math-16.png" />
            </Button>

            <Button
                Grid.Column="3"
                Width="24"
                Height="24"
                Command="{Binding RemoveSequenceCommand}"
                IsEnabled="{Binding HasSequenceSelected}"
                ToolTip="Remove current sequence">
                <Image Source="/TombEditor;component/Resources/icons_general/general_trash-16.png" />
            </Button>
        </sg:SpacedGrid>

        <!-- Row 1, Column 0: Camera list -->
        <Border
            Grid.Row="1"
            Grid.Column="0"
            BorderBrush="{DynamicResource Brush_Border}"
            BorderThickness="{x:Static darkUI:Defaults.BorderThickness}">
            <ListBox
                x:Name="cameraListBox"
                AllowDrop="True"
                Background="{DynamicResource Brush_Background_Light}"
                Drop="CameraListBox_Drop"
                ItemsSource="{Binding CameraList}"
                PreviewMouseLeftButtonDown="CameraListBox_PreviewMouseLeftButtonDown"
                PreviewMouseMove="CameraListBox_PreviewMouseMove"
                SelectedItem="{Binding SelectedCamera}"
                SelectionChanged="CameraListBox_SelectionChanged"
                SelectionMode="Extended">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <sg:SpacedGrid ColumnSpacing="{x:Static darkUI:Defaults.SmallThicknessWidth}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="{Binding Number}" />

                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Foreground="{DynamicResource Brush_Text_Secondary}"
                                Text="{Binding Timecode}" />
                        </sg:SpacedGrid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style BasedOn="{StaticResource {x:Type ListBoxItem}}" TargetType="ListBoxItem">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDuplicateIndex}" Value="True">
                                <Setter Property="Background" Value="#44FF4444" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>

        <!-- Row 1, Column 1: Numerical camera properties -->
        <sg:SpacedGrid
            Grid.Row="1"
            Grid.Column="1"
            Margin="{x:Static darkUI:Defaults.SmallThickness}"
            IsEnabled="{Binding CanEditProperties}"
            RowSpacing="{x:Static darkUI:Defaults.SmallThicknessWidth}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Label Grid.Row="0" Content="Speed:" />
            <controls:NumericUpDown
                Grid.Row="0"
                Grid.Column="1"
                FormatString="F2"
                Increment="0.1"
                Maximum="100"
                Minimum="0"
                Value="{Binding CameraSpeed}" />

            <Label Grid.Row="1" Content="FOV:" />
            <controls:NumericUpDown
                Grid.Row="1"
                Grid.Column="1"
                FormatString="F1"
                Increment="1"
                Maximum="180"
                Minimum="0"
                Value="{Binding CameraFov}" />

            <Label Grid.Row="2" Content="Roll:" />
            <controls:NumericUpDown
                Grid.Row="2"
                Grid.Column="1"
                FormatString="F1"
                Increment="1"
                Maximum="360"
                Minimum="0"
                Value="{Binding CameraRoll}" />

            <Label Grid.Row="3" Content="Rotation X:" />
            <controls:NumericUpDown
                Grid.Row="3"
                Grid.Column="1"
                FormatString="F1"
                Increment="1"
                Maximum="90"
                Minimum="-90"
                Value="{Binding CameraRotationX}" />

            <Label Grid.Row="4" Content="Rotation Y:" />
            <controls:NumericUpDown
                Grid.Row="4"
                Grid.Column="1"
                FormatString="F1"
                Increment="1"
                Maximum="360"
                Minimum="0"
                Value="{Binding CameraRotationY}" />

            <Label Grid.Row="5" Content="Timer:" />
            <controls:NumericUpDown
                Grid.Row="5"
                Grid.Column="1"
                Increment="1"
                Maximum="32767"
                Minimum="-32768"
                Value="{Binding CameraTimer}" />
        </sg:SpacedGrid>

        <!-- Row 1, Column 2: Flags -->
        <ScrollViewer
            Grid.Row="1"
            Grid.Column="2"
            Margin="{x:Static darkUI:Defaults.SmallThickness}"
            IsEnabled="{Binding CanEditProperties}"
            VerticalScrollBarVisibility="Auto">
            <controls:SpacedStack Spacing="{x:Static darkUI:Defaults.TinyThicknessWidth}">
                <Label Content="Flags:" FontWeight="SemiBold" />
                <CheckBox
                    x:Name="cbBit0"
                    Click="FlagCheckBox_Click"
                    Content="Cut to flyby from Lara position"
                    Tag="0" />
                <CheckBox
                    x:Name="cbBit1"
                    Click="FlagCheckBox_Click"
                    Content="Track entity position"
                    Tag="1" />
                <CheckBox
                    x:Name="cbBit2"
                    Click="FlagCheckBox_Click"
                    Content="Infinite loop"
                    Tag="2" />
                <CheckBox
                    x:Name="cbBit3"
                    Click="FlagCheckBox_Click"
                    Content="Create tracking camera"
                    Tag="3" />
                <CheckBox
                    x:Name="cbBit4"
                    Click="FlagCheckBox_Click"
                    Content="Focus on Lara's last head position"
                    Tag="4" />
                <CheckBox
                    x:Name="cbBit5"
                    Click="FlagCheckBox_Click"
                    Content="Focus on Lara's head"
                    Tag="5" />
                <CheckBox
                    x:Name="cbBit6"
                    Click="FlagCheckBox_Click"
                    Content="Snap back to Lara at end"
                    Tag="6" />
                <CheckBox
                    x:Name="cbBit7"
                    Click="FlagCheckBox_Click"
                    Content="Jump to camera (Timer field)"
                    Tag="7" />
                <CheckBox
                    x:Name="cbBit8"
                    Click="FlagCheckBox_Click"
                    Content="Freeze camera (Timer field)"
                    Tag="8" />
                <CheckBox
                    x:Name="cbBit9"
                    Click="FlagCheckBox_Click"
                    Content="Disable Look At exit"
                    Tag="9" />
                <CheckBox
                    x:Name="cbBit10"
                    Click="FlagCheckBox_Click"
                    Content="Cinematic mode"
                    Tag="10" />
                <CheckBox
                    x:Name="cbBit11"
                    Click="FlagCheckBox_Click"
                    Content="Let Lara move in cinematic"
                    Tag="11" />
                <CheckBox
                    x:Name="cbBit12"
                    Click="FlagCheckBox_Click"
                    Content="Unused"
                    Tag="12" />
                <CheckBox
                    x:Name="cbBit13"
                    Click="FlagCheckBox_Click"
                    Content="Unused"
                    Tag="13" />
                <CheckBox
                    x:Name="cbBit14"
                    Click="FlagCheckBox_Click"
                    Content="Activate heavy trigger"
                    Tag="14" />
                <CheckBox
                    x:Name="cbBit15"
                    Click="FlagCheckBox_Click"
                    Content="Unused"
                    Tag="15" />
            </controls:SpacedStack>
        </ScrollViewer>

        <!-- Row 2: Action buttons -->
        <sg:SpacedGrid Grid.Row="2" Grid.ColumnSpan="3" ColumnSpacing="{x:Static darkUI:Defaults.SmallThicknessWidth}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ToggleButton
                Grid.Column="0"
                Width="80"
                Height="24"
                IsChecked="{Binding IsPreviewActive}"
                ToolTip="Toggle live preview">
                <StackPanel Orientation="Horizontal">
                    <Image
                        Width="16"
                        Height="16"
                        Margin="0,0,4,0"
                        Source="/TombEditor;component/Resources/icons_actions/actions_3DView-16.png" />
                    <TextBlock VerticalAlignment="Center" Text="Preview" />
                </StackPanel>
            </ToggleButton>

            <Button
                Grid.Column="2"
                Width="24"
                Height="24"
                Command="{Binding AddCameraCommand}"
                IsEnabled="{Binding HasSequenceSelected}"
                ToolTip="Add camera at current view position">
                <Image Source="/TombEditor;component/Resources/icons_general/general_plus_math-16.png" />
            </Button>

            <Button
                Grid.Column="3"
                Width="24"
                Height="24"
                Command="{Binding DeleteSelectedCamerasCommand}"
                ToolTip="Delete selected camera(s)">
                <Image Source="/TombEditor;component/Resources/icons_general/general_trash-16.png" />
            </Button>
        </sg:SpacedGrid>

        <!-- Row 3: Timeline + playhead label + play/stop -->
        <sg:SpacedGrid Grid.Row="3" Grid.ColumnSpan="3" ColumnSpacing="{x:Static darkUI:Defaults.MediumThicknessWidth}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Height="60"
                BorderBrush="{DynamicResource Brush_Border}"
                BorderThickness="{x:Static darkUI:Defaults.BorderThickness}">
                <local:FlybyTimelineControl x:Name="timelineControl" />
            </Border>

            <Label
                Grid.Column="1"
                Width="80"
                VerticalAlignment="Center"
                Content="{Binding PlayheadTimecode}"
                ToolTip="Playhead timecode (MM:SS.CC)" />

            <Button
                Grid.Column="2"
                Width="60"
                Height="24"
                VerticalAlignment="Center"
                Command="{Binding TogglePlayStopCommand}"
                IsEnabled="{Binding HasSequenceSelected}"
                ToolTip="Play/Stop sequence">
                <StackPanel Orientation="Horizontal">
                    <Image
                        Width="16"
                        Height="16"
                        Source="/TombEditor;component/Resources/icons_actions/actions_play-16.png" />
                    <TextBlock
                        VerticalAlignment="Center"
                        Text="{Binding PlayStopIcon}" />
                </StackPanel>
            </Button>
        </sg:SpacedGrid>
    </sg:SpacedGrid>
</Window>
