<UserControl
    x:Class="TombEditor.Controls.FlybyTimeline.FlybyTimelineView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:TombEditor.Controls.FlybyTimeline"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="48"
    d:DesignWidth="716"
    Background="{DynamicResource Brush_Background}"
    mc:Ignorable="d">

	<Grid Margin="3,2,3,2">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="Auto" />
		</Grid.ColumnDefinitions>

		<!-- Left side: Two rows - timecode above, flyby selector below. -->
		<Grid Grid.Column="0" Margin="0,0,4,0" VerticalAlignment="Stretch">
			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<!-- Timecode label, right-aligned in the left panel. -->
			<TextBlock
                Width="73"
                VerticalAlignment="Center"
                HorizontalAlignment="Left"
                FontFamily="Courier New"
                FontSize="14"
                Foreground="#FFC0C0C0"
                Text="{Binding PlayheadTimecode}"
                TextAlignment="Right"
                ToolTip="Playhead timecode (MM:SS.CC)" Margin="37,0,0,0" />

			<!-- Flyby selector row. -->
			<StackPanel
                Grid.Row="1"
                Orientation="Horizontal"
                VerticalAlignment="Center">

				<ComboBox
                    x:Name="comboSequence"
                    Width="56"
                    Height="24"
                    VerticalAlignment="Center"
                    ItemsSource="{Binding AvailableSequences}"
                    SelectedItem="{Binding SelectedSequence}" />

				<Button
                    Width="23"
                    Height="24"
                    Margin="4,0,0,0"
                    VerticalAlignment="Center"
                    Command="{Binding AddSequenceCommand}"
                    ToolTip="Add new sequence">
					<Image
                        Width="16"
                        Height="16"
                        Source="pack://application:,,,/TombEditor;component/Resources/icons_general/general_plus_math-16.png"
                        RenderOptions.BitmapScalingMode="HighQuality" />
				</Button>

				<Button
                    Width="23"
                    Height="24"
                    Margin="4,0,0,0"
                    VerticalAlignment="Center"
                    Command="{Binding RemoveSequenceCommand}"
                    IsEnabled="{Binding HasSequenceSelected}"
                    ToolTip="Remove current sequence">
					<Image
                        Width="16"
                        Height="16"
                        Source="pack://application:,,,/TombEditor;component/Resources/icons_actions/actions_delete-16.png"
                        RenderOptions.BitmapScalingMode="HighQuality" />
				</Button>
			</StackPanel>
		</Grid>

		<!-- Center: Timeline control with border. -->
		<Border
            Grid.Column="1"
            BorderBrush="{DynamicResource Brush_Border}"
            BorderThickness="1">
			<local:FlybyTimelineControl x:Name="timelineControl" />
		</Border>

		<!-- Right side: Play/stop and add camera buttons. -->
		<StackPanel
            Grid.Column="2"
            Margin="2,0,0,0"
            Orientation="Horizontal"
            VerticalAlignment="Stretch">

			<Button
                Width="36"
                Margin="0"
                VerticalAlignment="Stretch"
                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                Command="{Binding TogglePlayStopCommand}"
                IsEnabled="{Binding HasSequenceSelected}"
                ToolTip="Play/Stop sequence" Height="41">
				<Image
                    Width="24"
                    Height="24"
                    Source="{Binding PlayStopIcon}"
                    RenderOptions.BitmapScalingMode="HighQuality" />
			</Button>

			<Button
                Width="36"
                Margin="0"
                VerticalAlignment="Stretch"
                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                Command="{Binding AddCameraCommand}"
                IsEnabled="{Binding HasSequenceSelected}"
                ToolTip="Add camera at current view position" Height="41">
				<Image
                    Width="24"
                    Height="24"
                    Source="pack://application:,,,/TombEditor;component/Resources/icons_transport/transport-plus.png"
                    RenderOptions.BitmapScalingMode="HighQuality" />
			</Button>
		</StackPanel>
	</Grid>
</UserControl>
